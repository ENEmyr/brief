{
  "name": "@brief/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy --env production",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@brief/schema": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "elysia": "^1.4.0",
    "@elysiajs/cors": "^1.4.0",
    "nanoid": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@brief/config": "workspace:*",
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20260605.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.30.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.20.0"
  }
}
